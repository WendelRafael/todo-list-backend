# Variáveis de ambiente do backend — copie para .env e preencha.
# Gere uma SECRET_KEY própria com:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"

# --- Uso local (desenvolvimento) ---
SECRET_KEY=troque-por-uma-chave-secreta
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,10.0.2.2

# --- Produção (deploy na internet) ---
# No servidor, use estes valores no lugar dos de cima (gere uma SECRET_KEY
# nova e exclusiva — nunca reaproveite a de desenvolvimento):
# SECRET_KEY=<chave-gerada-so-para-producao>
# DEBUG=False
# ALLOWED_HOSTS=seuusuario.pythonanywhere.com
